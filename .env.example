# ============================================================
# Receipt Scanner - Environment Variables
# Copy this file to .env and fill in your values.
# ============================================================

# ------------------------------------------------------------
# Database Configuration (PostgreSQL)
# ------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=receipt_scanner_db
DB_USERNAME=postgres
DB_PASSWORD=your-db-password

# ------------------------------------------------------------
# JWT Configuration
# ------------------------------------------------------------
# Generate a secure secret: openssl rand -hex 32
JWT_SECRET=your-super-secret-key-at-least-256-bits-long-replace-this
JWT_ACCESS_TOKEN_EXPIRATION_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRATION_MINUTES=10080

# ------------------------------------------------------------
# API Versioning
# ------------------------------------------------------------
API_VERSION=v1

# ------------------------------------------------------------
# AI Provider Configuration
# Set AI_PROVIDER to either "gemini" (default, free) or "openai"
# ------------------------------------------------------------
AI_PROVIDER=gemini

# Gemini Configuration (free tier  default provider)
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta

# OpenAI Configuration (optional  only used when AI_PROVIDER=openai)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o
OPENAI_API_URL=https://api.openai.com/v1/chat/completions

# ------------------------------------------------------------
# File Storage Configuration
# If Cloudinary credentials are set, cloud storage is used.
# Otherwise files are stored locally in FILE_UPLOAD_DIR.
# ------------------------------------------------------------
FILE_UPLOAD_DIR=uploads

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=receipts

# ------------------------------------------------------------
# Admin User Initialization
# Created automatically on first startup if not already exists.
# ------------------------------------------------------------
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-admin-password-here

# ------------------------------------------------------------
# Server Configuration
# ------------------------------------------------------------
SERVER_PORT=8080

# ------------------------------------------------------------
# Logging Configuration
# ------------------------------------------------------------
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_APP=DEBUG
LOG_FILE_PATH=logs/application.log
